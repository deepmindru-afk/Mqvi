# mqvi Server Configuration
# Bu dosyayı .env olarak kopyala ve değerleri düzenle.

# ─── Server ───
SERVER_HOST=0.0.0.0
SERVER_PORT=9090

# ─── Database ───
DATABASE_PATH=./data/mqvi.db

# ─── JWT ───
# GİZLİ! Rastgele uzun bir string olmalı. Örnek: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-TO-A-RANDOM-SECRET-STRING
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Encryption ───
# LiveKit credential'larını DB'de şifrelemek için AES-256 key (64 hex karakter = 32 byte)
# Üretmek için: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE-ME-RUN-openssl-rand-hex-32

# ─── Upload ───
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_SIZE=524288000
# Per-user storage quota in bytes (default: 10 GB)
# MQVI_DEFAULT_QUOTA_BYTES=10737418240
# HMAC secret for signed file URLs (base64-encoded, min 32 bytes)
# openssl rand -base64 32
MQVI_SIGNED_URL_SECRET=
# Previous secret for key rotation (optional, same format)
# MQVI_SIGNED_URL_SECRET_PREV=

# ─── CORS (opsiyonel) ───
# Ek origin'ler, virgülle ayrılmış.
# CORS_ORIGINS=https://yourdomain.com

# ─── LiveKit (opsiyonel — sadece ilk kurulum seed) ───
# Sunucu başladığında DB'de hiç LiveKit instance yoksa bu değerlerle bir tane oluşturulur.
# livekit.yaml'daki keys bölümüyle eşleşmeli. Sonraki yönetim admin panelden yapılır.
# Boş bırakılırsa seed atlanır.
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ─── TURN (optional — P2P 1-on-1 call relay fallback) ───
# coturn relay for direct P2P calls that fail behind restrictive NAT/firewall.
# Set up by deploy/coturn-setup.sh. Leave empty => STUN-only (no relay fallback).
# Shared HMAC secret — MUST match coturn's static-auth-secret (use-auth-secret).
# TURN_SECRET=
# Comma-separated TURN URLs handed to clients.
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# Comma-separated STUN URLs (default: Google STUN). Rarely needs changing.
# STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN credential lifetime in seconds (default 86400 = 24h; max 604800 = 7 days).
# TURN_CREDENTIAL_TTL_SECONDS=86400

# ─── Push Notifications (optional — mobile FCM) ───
# Path to the Firebase service-account JSON used to send push notifications.
# Default: ./firebase-service-account.json (relative to the server working dir).
# Place the JSON there and push works with no extra config. Leave the file absent
# => push is disabled and the server still runs (no error). Self-host friendly.
# FCM_CREDENTIALS_FILE=./firebase-service-account.json
